APP_TAG=latest

HTTP_PORT=80
SERVER_NAME=app.example.com
CLIENT_MAX_BODY_SIZE=50m
PROXY_READ_TIMEOUT=300
PROXY_SEND_TIMEOUT=300

SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:mysql://db.example.internal:3306/luoiflix_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Ho_Chi_Minh
SPRING_DATASOURCE_USERNAME=luoiflix
SPRING_DATASOURCE_PASSWORD=change-me
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false

MOVIEAPP_JWT_SECRET=replace-with-base64-secret
MOVIEAPP_JWT_ACCESS_TOKEN=8640000
MOVIEAPP_JWT_REFRESH_TOKEN=8640000
MOVIEAPP_FRONTEND_URL=https://app.example.com

CLOUDINARY_CLOUD_NAME=replace-me
CLOUDINARY_API_KEY=replace-me
CLOUDINARY_API_SECRET=replace-me
NEXT_PUBLIC_MEDIA_BASE_URL=https://media.lazy247.xyz
